# Copy this file to .env and fill in the values from your Google Cloud OAuth client.
# See README.md for how to create the credentials.

# From the OAuth 2.0 Client ID you created in Google Cloud Console.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must exactly match an Authorized redirect URI on that OAuth client.
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Port the server listens on. Keep 8080 so it matches the redirect URI above.
PORT=8080

# Path to the SQLite database file. Created (with its schema) on first run.
DATABASE_PATH=app.db

# Whether the session cookie has the Secure flag. Keep false over plain HTTP in
# dev; set true when serving over HTTPS.
COOKIE_SECURE=false
